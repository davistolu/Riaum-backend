{
  "name": "serene-space-backend",
  "version": "1.0.0",
  "description": "Backend for Serene Space mental health support platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "pnpm run build && node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "test": "jest",
    "db:setup": "node scripts/setup-database.js",
    "db:seed": "node scripts/seed-production.js",
    "db:seed-sample": "node scripts/seed-sample-data.js",
    "db:backup": "node scripts/backup-database.js",
    "db:restore": "node scripts/restore-database.js",
    "db:cleanup": "node scripts/cleanup-database.js",
    "db:migrate": "node scripts/migrate-database.js",
    "db:rollback": "node scripts/migrate-database.js --rollback",
    "db:health": "node scripts/health-check.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/express-session": "^1.18.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.4",
    "ua-parser-js": "^2.0.9",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "mental-health",
    "support",
    "chatbot",
    "peer-support",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Serene Space Team",
  "license": "MIT"
}
